{
  "name": "oski-agent",
  "version": "0.1.0",
  "description": "Slack-native internal ops agent for small teams. Reads approved context, uses a typed tool registry, drafts replies and actions, tracks cost, and can be extended with custom tools.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "agent:task": "tsx src/cli.ts",
    "agent:mock": "tsx src/test-cli.ts mock",
    "agent:queue": "tsx src/test-cli.ts queue",
    "agent:failures": "tsx src/test-cli.ts failures"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
