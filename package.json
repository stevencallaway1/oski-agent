{
  "name": "oski-agent",
  "version": "0.1.0",
  "description": "Open-source AI agent framework that learns, uses tools, and grows its capabilities over time. Built for AI-native internal team workflows.",
  "keywords": [
    "ai-agents",
    "agentic-ai",
    "ai-safety",
    "human-in-the-loop",
    "slack-bot",
    "typescript",
    "developer-tools",
    "open-source"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevencallaway1/oski-agent.git"
  },
  "homepage": "https://stevencallaway1.github.io/oski-agent/",
  "bugs": {
    "url": "https://github.com/stevencallaway1/oski-agent/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "demo": "tsx src/demo.ts",
    "site:css": "npx --yes tailwindcss@3.4.17 -c tailwind.site.config.cjs -i assets/tailwind-input.css -o assets/site.css --minify",
    "agent:task": "tsx src/cli.ts",
    "agent:mock": "tsx src/test-cli.ts mock",
    "agent:queue": "tsx src/test-cli.ts queue",
    "agent:failures": "tsx src/test-cli.ts failures"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.7"
  }
}
