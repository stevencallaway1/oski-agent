# -------------------------------------------------------
# Oski Agent Environment Variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env to git.
# -------------------------------------------------------

# --- Anthropic API (required for live model tasks, not npm run demo) ---
# Get from: https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model routing. Cheap model handles routing/triage; the reasoning model is
# promoted automatically for multi-step tasks. Any Anthropic model ID works.
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-5

# --- Slack (optional, leave blank to run CLI-only) ---
# See docs/SLACK_SETUP.md for a step-by-step guide.
# App-level token for Socket Mode (starts with xapp-)
OSKI_SLACK_APP_TOKEN=
# Bot user OAuth token (starts with xoxb-)
OSKI_SLACK_BOT_TOKEN=
# Channel Socket Mode accepts and scheduled results target (ID like C0123456789, or a name)
OSKI_SLACK_CHANNEL_ID=
# Signing secret, only needed for the HTTP Events API fallback (not Socket Mode)
OSKI_SLACK_SIGNING_SECRET=

# --- Safety and cost controls ---
# Comma-separated list of directories the agent may read/search.
# EMPTY = the agent can read NOTHING. There is no default access.
# Example: OSKI_WORKSPACE_ROOTS=/home/me/projects/my-repo,/home/me/notes
OSKI_WORKSPACE_ROOTS=

# Halt the queue when daily Anthropic spend crosses this USD threshold.
OSKI_DAILY_USD_CAP=2

# Comma-separated tool names allowed to take live (side-effectful) actions.
# EMPTY = everything runs in draft mode. Example: OSKI_LIVE_TOOLS=slack_post_draft
OSKI_LIVE_TOOLS=

# EXPERIMENTAL: allow the agent to author new tools via the Claude Code CLI.
# Default off. Read the "Safety model" section of the README before enabling.
OSKI_ENABLE_CODEGEN=false
# Path to the Claude Code CLI binary (only used when codegen is enabled).
CLAUDE_CLI_PATH=claude

# --- Scheduling (optional) ---
# Enable the example recurring cron tasks in src/channels/cron.ts.
OSKI_CRON_ENABLED=false
# Post a once-daily "I'm online" heartbeat to the Slack channel.
OSKI_HEARTBEAT_ENABLED=false
# IANA timezone used in the system prompt's "current time".
OSKI_TIMEZONE=UTC

# --- Server (only used for the HTTP Events API fallback) ---
PORT=3001
